<?xml version="1.0" encoding="utf-8"?>
<!--
    player_ui.xml — разметка интерфейса PlayerWindow

    margin="л,т,п,н"  — setContentsMargins layout-а этого элемента
    margin="8"         — все стороны одинаково
    spacing="6"        — setSpacing layout-а этого элемента

    Кастомные виджеты зарегистрированы в main.py:
        gradientImageLabel  → GradientImageLabel
        fixedComboBox       → FixedComboBox
        waveformSeekBar     → WaveformSeekBar
        visualizerWindow    → VisualizerWindow
-->

<!-- Корневой контейнер: VBox без отступов, нулевой spacing -->
<qwidget flex="h" margin="0" spacing="0">

    <!-- ═══════════════════════════════════════════════════════════════
         playlistBox: таблица + строка управления плейлистом
         margin="0" — без внешних отступов, как в оригинале
         ═══════════════════════════════════════════════════════════════ -->
    <qwidget id="playlistBox" flex="v"
             margin="0" spacing="0">

        <qtablewidget id="table" stretch="1" />

        <!-- Строка управления: Add / URL / cookies / Clear / Save / Load
             spacing="6" соответствует оригинальному playlist_menu.setSpacing(6) -->
        <qwidget id="playlistMenu" flex="h"
                 margin="0" spacing="6">

            <qpushbutton id="add_button" text="Add" connect="add_url" />

            <qlineedit id="url_input"
                       placeholder="URL for yt-dlp"
                       stretch="1" />

            <fixedComboBox id="cookie_browser"
                           items="No cookies,Firefox cookies,Chrome cookies,Chromium cookies,Brave cookies,Edge cookies" />

            <qpushbutton id="clear_button" text="Clear" connect="clear_playlist" />
            <qpushbutton id="save_button"  text="Save"  connect="save_playlist" />
            <qpushbutton id="load_button"  text="Load"  connect="load_playlist" />

        </qwidget>

    </qwidget>

    <!-- ═══════════════════════════════════════════════════════════════
         NowDisplay: обложка / мета / визуализатор / waveform-seekbar
         ═══════════════════════════════════════════════════════════════ -->
    <qwidget Align="AlignCenter" id="NowDisplay"
             flex="v" margin="0" spacing="0">

        <!-- Фоновое изображение — позиционируется вручную через resizeEvent -->
        <gradientImageLabel id="cover_background"
                            visible="true" blur_effect="16" nolayout="true"/>

        <systemmenubar id="MainMenuBar" visible="true"/>

        <!-- Строка: обложка + мета + визуализатор
             margin="16,16,16,0" → left=16 top=16 right=16 bottom=0  -->

        <qwidget stretch="1" />
        <qwidget id="playNowRow" flex="h"
                 margin="0,16,0,0" spacing="0"
                 stretch="1">

            <gradientImageLabel id="cover_label"
                                fixed-width="256" fixed-height="256" blur_effect="0"/>


            <!-- Мета-блок: заголовок + исполнитель + альбом, прижаты к центру -->

            <!-- Визуализатор -->

        </qwidget>

        <qwidget Align="AlignHCenter" id="metaBlock" flex="v"
                    margin="0,16,0,16" spacing="0"
                    stretch="1">
                <!-- верхний распор -->
                <qwidget stretch="1" />
                <qlabel id="track_title_label"
                        style="color:#f5f5f5; font-size:19px; font-weight:700;
                               margin:2px; margin-left:10px;" />
                <qlabel id="artist_label"
                        style="color:#a8a8a8; font-size:14px;
                               margin:2px; margin-left:10px;" />
                <qlabel id="album_label"
                        style="color:#a8a8a8; font-size:14px;
                               margin:2px; margin-left:10px;" />
                <!-- нижний распор -->
                <qwidget stretch="1" />
        </qwidget>

        <!-- Waveform seek bar — без отступов, прилегает вплотную к строке выше -->
        <qwidget margin="56,16,56,0" Align="AlignVCenter" flex="h">
            <waveformSeekBar id="position_slider" />       

        </qwidget> 

        <visualizerWindow margin="8,8,8,0" id="visualizer_window" audio_bar_count="258" fixed-height="128" />



        <qframe id="nowPlaying" flex="v"
            margin="8,0,8,8" spacing="4">

        <!-- Строка кнопок управления -->
        <qwidget stretch="1" />

        <qwidget id="buttonRow" flex="h"
                 margin="0" spacing="8">

            <!-- левый распор -->
            <qwidget stretch="1" />

            <qpushbutton id="prev_button"    connect="play_previous" />
            <qpushbutton id="stop_button"    connect="stop_playback" />
            <qpushbutton id="play_button"    connect="play_selected_or_current" />
            <qpushbutton id="pause_button"   connect="pause_playback" />
            <qpushbutton id="next_button"    connect="play_next" />
            <qpushbutton id="restart_button" connect="restart_current_stream" />

            <!-- правый распор — в 3 раза шире левого, прижимает кнопки к центру -->
            <qwidget stretch="3" />

            <qlabel id="time_label" text="0:00 / 0:00"
                    style="color:#ffffff;" />

            <qpushbutton id="mode_button" connect="toggle_play_mode" />

            <qslider id="volume_slider"
                     orientation="h"
                     min="0" max="100" value="80"
                     fixed-width="120"
                     connect="on_volume_slider_changed" />

        </qwidget>

        <qlabel id="status_label" text="Ready"
            style="color:#8f8f8f; padding:5px 10px; border-top:1px solid #161616;" />

    </qframe>

    </qwidget>

    <!-- ═══════════════════════════════════════════════════════════════
         nowPlaying: транспорт + время + громкость
         margin="8,8,8,8" соответствует оригинальному setContentsMargins(8,8,8,8)
         ═══════════════════════════════════════════════════════════════ -->
</qwidget>
